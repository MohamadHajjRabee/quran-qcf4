    <div class="toast" id="toast"><i class="fa-solid fa-circle-check"></i> تم التحديث بنجاح!</div>

    <!-- Load data files -->
    <script src="./hafs_pages.js" defer></script>
    <script src="./hafs_verses.js" defer></script>

    <!-- Load Logics -->
    <script src="./main.js" defer></script>

    <!-- Dark Mode Toggle (standalone, does not touch main.js) -->
    <script>
        (function () {
            const btn = document.getElementById('themeToggle');
            const icon = document.getElementById('themeIcon');
            const KEY = 'quran-copier-theme';

            function applyTheme(dark) {
                document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
                icon.className = dark ? 'fa-solid fa-sun' : 'fa-solid fa-moon';
                localStorage.setItem(KEY, dark ? 'dark' : 'light');
            }

            // Init from saved preference
            const saved = localStorage.getItem(KEY);
            if (saved === 'dark') applyTheme(true);

            btn.addEventListener('click', function () {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                applyTheme(!isDark);
            });
        })();
    </script>
