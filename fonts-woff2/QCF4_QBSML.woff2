                <ul>
                    <li><a href="https://t.me/Elgharibi/983" target="_blank">باقة قنوات أحمد الغريب</a></li>
                    <li><a href="https://t.me/iElgharibBot" target="_blank">روبوت الشكاوى والاقتراحات</a></li>
                    <li><a href="https://t.me/Am9li9" target="_blank">الرسائل المباشرة مع المدير</a></li>
                    <li><a href="https://t.me/ElgharibFonts" target="_blank">نقاشات خطوط أحمد الغريب</a></li>
                </ul>
            </div>

            <!-- YouTube & Instagram -->
            <div class="social-section">
                <h3><i class="fa-solid fa-video" style="color:#ff0000;"></i> الميديا والشبكات</h3>
                <ul>
                    <li><a href="https://youtube.com/@am9li9" target="_blank"><i class="fa-brands fa-youtube"
                                style="color:#ff0000;"></i> قناة اليوتيوب الرسمية</a></li>
                    <li><a href="https://www.instagram.com/am9li9" target="_blank"><i class="fa-brands fa-instagram"
