                    <i class="fa-solid fa-link"></i>
                </a>
            </div>

            <!-- Main Hero Content (Compact Redesigned) -->
            <div class="hero-container">
                <h1 class="hero-new-title hero-anim" id="heroTitle">يَارَبِّ رِضَاكَ وَالجَنَّةَ</h1>

