    <!-- External CSS -->
    <link rel="stylesheet" href="./styles.css">
</head>

<body>

    <div class="container">
        <!-- Hero Section — Completely Redesigned -->
        <header class="hero-section" id="heroSection">

            <!-- Top Identity Bar: Logo + Name + Dark Mode Toggle -->
            <div class="hero-identity-bar hero-anim" id="heroVisual">
                <img src="./IMG_8030.JPEG" alt="شعار أبا محمد" class="hero-logo-img">
                <div class="hero-identity-text">
                    <span class="hero-identity-name">
                        أحمَد الغَريب
                        <i class="fa-solid fa-circle-check"
                            style="color: #1DA1F2; font-size: 0.85em; margin-right: 5px;"></i>
                    </span>
                    <span class="hero-identity-label" style="font-size: 0.75rem; opacity: 0.7;">أبا مُحمَّد</span>
                </div>
                <button class="theme-toggle" id="themeToggle" aria-label="تبديل الوضع الليلي" title="الوضع الليلي">
                    <i class="fa-solid fa-moon" id="themeIcon"></i>
                </button>
                <a href="https://linktr.ee/am9li9" target="_blank" class="social-link-btn" aria-label="جميع الحسابات"
