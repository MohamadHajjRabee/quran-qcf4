                    <i class="fa-solid fa-xmark"></i>
                </button>

                <!-- Page Title -->
                <div class="pv-title" id="pvTitle">
                    <i class="fa-solid fa-book-quran"></i>
                    <span id="pvTitleText">الصفحة ١</span>
                </div>

                <!-- Font Info -->
                <div class="pv-font-info" id="pvFontInfo">
                    <i class="fa-solid fa-font"></i>
                    اسم ملف الخط المطلوب: <b id="pvFontName">QCF4_Hafs_01_W</b>
                </div>
            </div>

            <div class="pv-toolbar-row pv-toolbar-controls">
                <!-- Navigation -->
                <div class="pv-nav-group">
                    <button class="pv-nav-btn" id="pvNextPage" title="الصفحة التالية">
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                    <div class="pv-page-select-wrap">
                        <select id="pvPageSelect" class="pv-page-select">
                            <option value="" disabled selected>اختر صفحة</option>
                        </select>
                    </div>
                    <button class="pv-nav-btn" id="pvPrevPage" title="الصفحة السابقة">
                        <i class="fa-solid fa-chevron-left"></i>
                    </button>
                </div>

                <!-- Search in viewer -->
                <div class="pv-search-group">
                    <div class="pv-search-input-wrap">
                        <i class="fa-solid fa-magnifying-glass"></i>
                        <input type="text" id="pvSearchInput" class="pv-search-input" placeholder="بحث عن آية..."
                            autocomplete="off" />
                    </div>
                </div>

                <!-- Copy Button -->
                <button class="pv-action-btn pv-copy-btn" id="pvCopyBtn" title="نسخ رموز الصفحة">
                    <i class="fa-solid fa-copy"></i>
                    <span>نسخ الصفحة</span>
                </button>
            </div>

            <!-- Search Results Dropdown -->
            <div class="pv-search-results" id="pvSearchResults" style="display: none;"></div>
        </div>

        <!-- Page Content Area -->
        <div class="pv-content" id="pvContent">
            <div class="pv-page-card" id="pvPageCard">
                <div class="qcf-text-area pv-qcf-text" id="pvQcfText" dir="rtl"></div>
            </div>
        </div>

        <!-- Bottom Page Navigation (Mobile-friendly) -->
        <div class="pv-bottom-nav">
            <button class="pv-bottom-btn" id="pvBottomNext">
