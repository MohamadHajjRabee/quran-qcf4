            <div class="pv-bottom-page-num" id="pvBottomPageNum">١ / ٦٠٤</div>
            <button class="pv-bottom-btn" id="pvBottomPrev">
                <span>السابقة</span>
                <i class="fa-solid fa-chevron-left"></i>
            </button>
        </div>
